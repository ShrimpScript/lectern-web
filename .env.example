# ── Lectern web environment ───────────────────────────────────────
# The marketing site + dashboard RUN WITHOUT any of these (dashboard shows seed data).
# Set them to enable real cloud features. NEVER put user source/keys here — this app
# only handles account/billing/usage/sync-index. See Lectern-Brain privacy notes.

# Database — libSQL/SQLite (free).
#   Local dev: leave BLANK — defaults to a local file (.data/lectern-dev.db).
#              Run `npm run setup` once to create the tables.
#   Production: a Turso URL (free tier), e.g. libsql://your-db.turso.io
DATABASE_URL=
DATABASE_AUTH_TOKEN=   # Turso auth token (production only)

# Auth (Auth.js) — Google + GitHub + email
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Billing (Stripe)

# Transactional email (Resend) — verification, reset, receipts, invites, contact
RESEND_API_KEY=
EMAIL_FROM="Lectern <noreply@getlectern.vercel.app>"
CONTACT_TO="hello@getlectern.vercel.app"

# Object storage for E2E-encrypted sync blobs + release artifacts (S3/Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Entitlement token signing (EdDSA private key, base64) — engine verifies with the public key
ENTITLEMENT_SIGNING_KEY=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://getlectern.vercel.app
